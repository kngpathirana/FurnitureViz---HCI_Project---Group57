rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own data
      allow read: if isOwner(userId);
      
      // Only allow user creation during registration (handled by server)
      // Regular users cannot update their own data directly
      allow write: if false;
    }
    
    // Designs collection
    match /designs/{designId} {
      // Users can read their own designs
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can create designs with their userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own designs
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own designs
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Furniture templates collection (read-only for users)
    match /furnitureTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admins can write (handle via backend)
    }
  }
}
